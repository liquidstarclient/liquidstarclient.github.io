{
  "name": "liquid-star-website",
  "version": "1.0.0",
  "private": true,
  "type": "module",
  "engines": {
    "node": ">=22.0.0"
  },
  "scripts": {
    "build": "node scripts/build-static.mjs",
    "dev": "npm run build && wrangler dev",
    "deploy": "npm run build && wrangler deploy",
    "check": "node --check worker/index.js && node --check scripts/build-static.mjs",
    "db:local": "wrangler d1 execute liquid-star-tickets --local --file=worker/schema.sql",
    "db:remote": "wrangler d1 execute liquid-star-tickets --remote --file=worker/schema.sql"
  },
  "devDependencies": {
    "wrangler": "4.103.0"
  }
}
